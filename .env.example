# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/google-demo"

# Auth (NextAuth/Auth.js)
AUTH_SECRET="your_nextauth_secret_here"
AUTH_GOOGLE_ID="your_google_client_id_here"
AUTH_GOOGLE_SECRET="your_google_client_secret_here"

# Corsair
CORSAIR_KEK="your_corsair_kek_base64_here"
# Required in production: signs/verifies inbound Corsair webhooks.
CORSAIR_WEBHOOK_SECRET=""

# Google Gemini (Optional locally; AI features degrade without it)
GEMINI_API_KEY=""

# Upstash Redis (Optional locally; falls back to in-memory cache + no rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Stripe (Optional locally; checkout is mocked without it)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""              # the Pro plan recurring Price id (price_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Background jobs: set in production so only Vercel Cron can run /api/jobs/process
CRON_SECRET=""

# Sentry error tracking (Optional; no-op until set). Server + browser DSNs.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Application
NEXT_PUBLIC_APP_URL="https://mail.gusion.in"

# Product Admin Configuration
# Comma-separated list of emails allowed to bypass staff checks
PRODUCT_ADMIN_EMAILS="admin@gusion.in,operator@gusion.in"
